            "value" : "イージング"
          }
        }
      }
    },
    "Easing curve for the retreat movement when source and target are close together." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ソースとターゲットが近接している場合の退避移動に使うイージングカーブ。"
          }
        }
      }
    },
