    "Auto" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自動"
          }
        }
      }
    },
    "Automatically adjust mesh resolution based on the genie direction. Uses higher resolution along the animation axis." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アニメーション方向に応じてメッシュ解像度を自動調整します｡"
          }
        }
      }
    },
