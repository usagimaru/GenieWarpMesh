    },
    "Mesh Grid" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "メッシュグリッド"
          }
        }
      }
    },
    "Mesh Resolution" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "メッシュ解像度"
          }
        }
      }
    },
    "Number of divisions in the warp mesh. Higher values produce smoother deformation but use more resources." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ワープメッシュの分割数。値が大きいほど変形が滑らかになりますが、負荷が増加します。"
          }
        }
      }
    },
    "Phase Control" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "フェーズ制御"
          }
        }
      }
    },
    "Position of Bézier control point P1 along the path. Affects the departure angle from the source window." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ベジェ制御点 P1 のパス上の位置。元ウインドウからの出発角度に影響します。"
          }
        }
      }
    },
    "Position of Bézier control point P2 along the path. Affects the arrival angle at the target." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ベジェ制御点 P2 のパス上の位置。ターゲットへの到着角度に影響します。"
          }
        }
      }
    },
    "Progress point where the retreat movement completes. Controls when the window finishes moving to the corrected position." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "退避移動が完了する進行度。補正位置への移動が終わるタイミングを制御します。"
          }
        }
      }
    },
    "Progress point where the sliding motion begins. Overlaps with the shrink phase for smooth transition." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "移動が始まる進行度。収縮フェーズと重なることで滑らかに遷移します。"
          }
        }
      }
    },
    "Raw time cutoff for animation. 'Early' skips the beginning, 'Late' trims from the end (as subtraction from 1.0)." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アニメーションの rawT カットオフ。序盤と終盤をそれぞれカット。"
          }
        }
      }
    },
    "Reset All" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すべてリセット"
          }
        }
