    "Strength of the stretching effect. Higher values make trailing edges lag more behind leading edges." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "間延びの強さ。値が大きいほど後方の辺が先頭の辺から大きく遅れます。"
          }
        }
      }
    },
